# Copy this file to .env and fill in real values. Never commit .env.

# Generate a new key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-real-secret-key

# Set to False in production
DEBUG=True

# Comma-separated list of hostnames/IPs (e.g. studybud.example.com,www.studybud.example.com)
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated origins allowed to make CORS/CSRF requests to the API
# (e.g. https://studybud.example.com,https://app.example.com)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
